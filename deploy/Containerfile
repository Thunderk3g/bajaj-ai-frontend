# Bajaj AI Platform — landing-frontend
# Multi-stage: build the static site, then serve it from a tiny nginx image.
# Mirrors the existing ai-infra agent pattern (one nginx:alpine container per frontend,
# joined to shared-network, fronted by shared-nginx). Base images come from the internal
# Bajaj Artifactory mirror on the VM.

# ---- build ----
# Fully-qualified base images: the VM's registries.conf uses
# short-name-mode = enforcing, where bare `node:20-alpine` fails to resolve.
FROM docker.io/library/node:20-alpine AS build
WORKDIR /app
COPY package.json package-lock.json* ./
RUN npm ci --no-audit --no-fund || npm install --no-audit --no-fund
COPY . .
RUN npm run build

# ---- serve ----
FROM docker.io/library/nginx:alpine
COPY deploy/landing.nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
HEALTHCHECK --interval=30s --timeout=3s --retries=3 \
  CMD wget -qO- http://127.0.0.1/ >/dev/null 2>&1 || exit 1
